{
  "$defs": {
    "HuntBudgetConfigModel": {
      "additionalProperties": true,
      "properties": {
        "max_duration_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 14400.0,
          "title": "Max Duration Seconds"
        },
        "high_value_target_time_budget_pct": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 0.4,
          "title": "High Value Target Time Budget Pct"
        },
        "stop_when_high_confidence_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 5,
          "title": "Stop When High Confidence Count"
        },
        "stop_when_total_findings": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 50,
          "title": "Stop When Total Findings"
        },
        "max_concurrent_probes": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 5,
          "title": "Max Concurrent Probes"
        },
        "countdown_visible": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Countdown Visible"
        }
      },
      "title": "HuntBudgetConfigModel",
      "type": "object"
    },
    "HuntModeConfigModel": {
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "default": false,
          "title": "Enabled",
          "type": "boolean"
        },
        "skip_subdomain_enumeration": {
          "default": true,
          "title": "Skip Subdomain Enumeration",
          "type": "boolean"
        },
        "skip_passive_checks": {
          "default": false,
          "title": "Skip Passive Checks",
          "type": "boolean"
        },
        "high_value_categories": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "High Value Categories"
        },
        "low_hanging_fruit": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "title": "Low Hanging Fruit"
        },
        "deduplicate_against_history": {
          "default": true,
          "title": "Deduplicate Against History",
          "type": "boolean"
        }
      },
      "title": "HuntModeConfigModel",
      "type": "object"
    },
    "ToolsConfigModel": {
      "additionalProperties": true,
      "properties": {
        "timeout_seconds": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 120,
          "title": "Timeout Seconds"
        },
        "retry_attempts": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 2,
          "title": "Retry Attempts"
        },
        "retry_backoff_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 2.0,
          "title": "Retry Backoff Seconds"
        },
        "retry_backoff_multiplier": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 1.0,
          "title": "Retry Backoff Multiplier"
        },
        "retry_max_backoff_seconds": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 2.0,
          "title": "Retry Max Backoff Seconds"
        },
        "retry_on_timeout": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Retry On Timeout"
        },
        "retry_on_error": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Retry On Error"
        },
        "retry_jitter": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": 0.25,
          "title": "Retry Jitter"
        },
        "subfinder": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Subfinder"
        },
        "assetfinder": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Assetfinder"
        },
        "amass": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": false,
          "title": "Amass"
        },
        "httpx": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Httpx"
        },
        "gau": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Gau"
        },
        "waybackurls": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Waybackurls"
        },
        "katana": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Katana"
        },
        "nuclei": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": true,
          "title": "Nuclei"
        }
      },
      "title": "ToolsConfigModel",
      "type": "object"
    }
  },
  "additionalProperties": true,
  "properties": {
    "target_name": {
      "title": "Target Name",
      "type": "string"
    },
    "output_dir": {
      "title": "Output Dir",
      "type": "string"
    },
    "http_timeout_seconds": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": 12,
      "title": "Http Timeout Seconds"
    },
    "mode": {
      "title": "Mode",
      "type": "string"
    },
    "cache": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "title": "Cache"
    },
    "tools": {
      "anyOf": [
        {
          "$ref": "#/$defs/ToolsConfigModel"
        },
        {
          "type": "null"
        }
      ]
    },
    "hunt_mode": {
      "anyOf": [
        {
          "$ref": "#/$defs/HuntModeConfigModel"
        },
        {
          "type": "null"
        }
      ]
    },
    "hunt_budget": {
      "anyOf": [
        {
          "$ref": "#/$defs/HuntBudgetConfigModel"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "target_name",
    "output_dir",
    "mode"
  ],
  "title": "ConfigModel",
  "type": "object"
}