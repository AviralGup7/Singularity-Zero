{
  "target_name": "square-bounty",
  "output_dir": "output",
  "http_timeout_seconds": 15,
  "mode": "idor",
  "cache": {
    "enabled": true
  },
  "tools": {
    "timeout_seconds": 90,
    "retry_attempts": 2,
    "retry_backoff_seconds": 2.0,
    "retry_backoff_multiplier": 1.0,
    "retry_max_backoff_seconds": 2.0,
    "retry_on_timeout": true,
    "retry_on_error": true,
    "subfinder": true,
    "assetfinder": true,
    "amass": false,
    "httpx": true,
    "gau": true,
    "waybackurls": true,
    "katana": true,
    "nuclei": true
  },
  "httpx": {
    "threads": 30,
    "timeout_seconds": 15,
    "probe_timeout_seconds": 5,
    "extra_args": []
  },
  "gau": {
    "timeout_seconds": 90,
    "extra_args": ["--providers", "wayback"]
  },
  "waybackurls": {
    "timeout_seconds": 90,
    "extra_args": []
  },
  "katana": {
    "timeout_seconds": 90,
    "extra_args": ["-silent", "-d", "2", "-js-crawl"]
  },
  "nuclei": {
    "timeout_seconds": 90,
    "dedupe_history": true,
    "feedback_target_limit": 40,
    "severity": ["medium", "high", "critical"],
    "adaptive_tags": {
      "redirect": ["redirect", "open-redirect"],
      "upload": ["file", "upload"],
      "auth": ["auth", "oauth"],
      "api": ["api", "exposure"],
      "idor": ["idor", "insecure-direct-object"],
      "ssrf": ["ssrf", "callback"],
      "lfi": ["lfi", "file-read", "path-traversal"],
      "debug": ["debug", "exposure", "misconfig"]
    },
    "fallback_tags": ["exposure", "misconfig", "default"],
    "extra_args": ["-rate-limit", "30"]
  },
  "scoring": {
    "weights": {
      "admin": 10,
      "auth": 8,
      "login": 8,
      "upload": 9,
      "redirect": 7,
      "callback": 7,
      "api": 6,
      "graphql": 6,
      "debug": 5,
      "internal": 5,
      "file": 4,
      "idor": 9,
      "ssrf": 9,
      "lfi": 8,
      "param": 5
    },
    "custom_keyword_bonus": 2,
    "contexts": {
      "api_heavy": {
        "bonus": 3,
        "keywords": ["/api/", "graphql", "swagger", "openapi"]
      },
      "auth_heavy": {
        "bonus": 3,
        "keywords": ["/auth", "/login", "/oauth", "token", "session"]
      },
      "parameter_heavy": {
        "bonus": 2,
        "keywords": ["=", "?", "filter", "sort", "page"]
      },
      "file_heavy": {
        "bonus": 2,
        "keywords": ["upload", "file", "download", "attachment"]
      }
    },
    "modes": {
      "fast": {
        "param_bonus": 2,
        "parameter_keywords": ["id", "page", "q"],
        "path_keywords": ["/api/"]
      },
      "deep": {
        "param_bonus": 4,
        "parameter_keywords": ["id", "user", "account", "order", "url", "callback"],
        "path_keywords": ["/api/", "/internal/", "/debug/"]
      },
      "idor": {
        "param_bonus": 6,
        "parameter_keywords": ["id", "user", "account", "profile", "order", "object", "member", "tenant"],
        "path_keywords": ["/users/", "/accounts/", "/profiles/", "/orders/"]
      },
      "ssrf": {
        "param_bonus": 6,
        "parameter_keywords": ["url", "uri", "dest", "redirect", "callback", "image", "feed"],
        "path_keywords": ["/proxy", "/fetch", "/callback", "/webhook"]
      }
    }
  },
  "filters": {
    "priority_limit": {
      "default": 50,
      "api_heavy": 200,
      "small_target": 50
    },
    "archive_host_threshold": 250,
    "adaptive_url_cap": true,
    "max_collected_urls": 1400,
    "priority_keywords": [
      "/api/", "/admin", "/auth", "/login", "/oauth",
      "/callback", "/redirect", "/upload", "/file",
      "/debug", "/internal"
    ],
    "ignore_extensions": [
      ".png", ".jpg", ".jpeg", ".gif", ".svg", ".webp",
      ".css", ".woff", ".woff2", ".ttf", ".eot", ".ico",
      ".mp4", ".mp3", ".avi", ".mov", ".pdf", ".zip"
    ],
    "stage_timeout_overrides": {
      "subdomains": 180,
      "live_hosts": 180,
      "urls": 120,
      "parameters": 60
    }
  },
  "screenshots": {
    "enabled": false
  },
  "concurrency": {
    "nuclei_workers": 3
  },
  "output": {
    "dedupe_aliases": true,
    "write_artifact_manifest": true
  },
  "analysis": {
    "enabled": true,
    "sensitive_data_scanner": true,
    "header_checker": true,
    "cookie_security_checker": true,
    "cors_misconfig_checker": true,
    "cache_control_checker": true,
    "jsonp_endpoint_checker": true,
    "frontend_config_exposure_checker": true,
    "directory_listing_checker": true,
    "debug_artifact_checker": true,
    "ai_endpoint_exposure_analyzer": true,
    "token_leak_detector": true,
    "ssrf_candidate_finder": true,
    "idor_candidate_finder": true,
    "technology_fingerprint": true,
    "anomaly_detector": true,
    "response_snapshot_system": false,
    "response_diff_engine": false,
    "flow_detector": false,
    "smart_payload_suggestions": true,
    "cross_tenant_pii_risk_analyzer": true,
    "server_side_injection_surface_analyzer": true,
    "payment_flow_intelligence": true,
    "payment_provider_detection": true,
    "service_enrichment": true,
    "behavior_analysis_layer": false,
    "options_method_probe": true,
    "origin_reflection_probe": true,
    "head_method_probe": true,
    "cors_preflight_probe": true,
    "trace_method_probe": false,
    "auto_max_speed_mode": false,
    "service_scan_max_hosts": 15,
    "service_scan_ports": [80, 443, 3000, 5000, 8000, 8080, 8443],
    "service_scan_workers": 6,
    "service_scan_timeout_seconds": 4,
    "service_scan_rate_per_second": 3,
    "admin_path_detection_limit": 12,
    "timeout_seconds": 15,
    "max_response_bytes": 120000,
    "max_live_hosts": 15,
    "max_priority_urls": 50,
    "max_workers": 6,
    "request_rate_per_second": 2.0,
    "request_burst": 1.5,
    "deep_analysis_top_n": 6,
    "response_cache_ttl_hours": 24,
    "enable_idor_comparison": true,
    "idor_compare_limit": 8,
    "idor_compare_similarity_threshold": 0.55,
    "behavior_analysis_limit": 4,
    "behavior_variants_per_endpoint": 2,
    "options_probe_limit": 8,
    "origin_reflection_probe_limit": 6,
    "head_method_probe_limit": 6,
    "cors_preflight_probe_limit": 6,
    "trace_method_probe_limit": 4,
    "response_diff_limit": 8,
    "privilege_escalation_limit": 8,
    "state_transition_limit": 8,
    "parameter_dependency_limit": 8,
    "redirect_chain_limit": 6,
    "auth_boundary_redirect_limit": 6,
    "path_traversal_limit": 10,
    "command_injection_limit": 8,
    "xxe_probe_limit": 6,
    "ssrf_probe_limit": 8,
    "open_redirect_limit": 8,
    "crlf_injection_limit": 8,
    "host_header_limit": 6,
    "ssti_probe_limit": 8,
    "nosql_injection_limit": 8,
    "deserialization_limit": 6,
    "path_traversal_active_probe": true,
    "command_injection_active_probe": true,
    "xxe_active_probe": true,
    "ssrf_active_probe": true,
    "open_redirect_active_probe": true,
    "crlf_injection_probe": true,
    "host_header_injection_probe": true,
    "ssti_active_probe": true,
    "nosql_injection_probe": true,
    "deserialization_probe": true,
    "http_smuggling_probe": false,
    "http2_probe": false,
    "oauth_flow_analyzer": true,
    "websocket_message_probe": false,
    "smuggling_probe_limit": 8,
    "http2_probe_limit": 6,
    "oauth_probe_limit": 8,
    "websocket_probe_limit": 6,
    "payload_suggestion_limit": 14
  },
  "review": {
    "manual_verification_limit": 5,
    "top_findings_limit": 4,
    "verified_exploit_limit": 3,
    "attack_graph_node_limit": 180,
    "attack_graph_edge_limit": 260,
    "attack_graph_chain_limit": 10,
    "attack_graph_max_depth": 3
  },
  "extensions": {
    "blackbox_validation": {
      "selector": {
        "planner_enabled": true,
        "max_plans": 6
      },
      "scoring": {
        "ssrf": { "base": 0.44, "cap": 0.97, "max_total_bonus": 0.40 },
        "xss": { "base": 0.50, "cap": 0.94, "max_total_bonus": 0.35, "min_independent_signals": 2 },
        "ssti": { "base": 0.45, "cap": 0.90, "max_total_bonus": 0.35, "min_independent_signals": 2 },
        "cors": { "base": 0.45, "cap": 0.93 },
        "jwt_weakness": { "base": 0.45, "cap": 0.95 },
        "cache_poisoning": { "base": 0.45, "cap": 0.92 },
        "graphql_abuse": { "base": 0.45, "cap": 0.92 },
        "race_condition": { "base": 0.45, "cap": 0.92 }
      },
      "calibration": {
        "min_independent_signals": 1,
        "ssrf_active_probe_enabled": true,
        "xss_baseline_required": true,
        "ssti_baseline_required": true,
        "token_replay_block_by_default": true,
        "max_concurrent_race_workers": 4,
        "cache_poisoning_unkeyed_headers": [
          "X-Forwarded-Host", "X-Original-URL", "X-Host", "X-Forwarded-Scheme"
        ],
        "jwt_test_secrets": [
          "secret", "password", "changeme", "admin",
          "1234567890", "supersecret"
        ]
      },
      "token_replay_safety": {
        "authorized_replay": false,
        "max_replay_attempts_per_token": 3,
        "max_replay_attempts_per_host": 5
      },
      "scope": {
        "block_active_when_unscoped": true,
        "log_warning_when_unscoped": true,
        "treat_unscoped_as_out_of_scope": true
      }
    },
    "callback": {
      "base_url": "",
      "provider": "",
      "token": ""
    }
  },
  "notifications": {
    "webhook_url": "",
    "webhook_type": "generic",
    "notify_on_success": true,
    "notify_on_failure": true,
    "include_finding_summary": true
  },
  "threat_intel": {
    "epss_endpoint": "https://api.first.org/data/v1/epss",
    "epss_cache_ttl_seconds": 86400,
    "cisa_kev_endpoint": "https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json",
    "cisa_kev_cache_ttl_seconds": 21600,
    "test_mode": false
  },
  "_project": {
    "name": "Square Bug Bounty",
    "description": "Pre-configured for Square's bug bounty program (bugcrowd.com/square). Focuses on payment/checkout, customer data exposure, banking security, and hardware/firmware.",
    "program_url": "https://bugcrowd.com/square",
    "scope": "*.square.com, *.squareup.com, square.online, weebly.com",
    "rewards": "P1: $5k-$18k, P2: $1k-$5k, P3: $250-$1k",
    "exclusions": [
      "Logout CSRF",
      "Lack of rate limiting",
      "Prompt injection without security impact",
      "Self-XSS without impact",
      "Broken link hijacking",
      "Missing cookie flags on non-sensitive cookies",
      "Password length issues",
      "Public encryption keys",
      "Username/email enumeration without mass recovery",
      "Cache poisoning resulting only in DoS",
      "Third-party vendor vulnerabilities"
    ],
    "rate_limits": {
      "httpx_threads": 30,
      "nuclei_rate_limit": 30,
      "request_rate_per_second": 2.0
    }
  }
}
