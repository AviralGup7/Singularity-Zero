      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(rate(cyber_pipeline_analyzer_executions_total{status=\"error\"}[5m])) / sum(rate(cyber_pipeline_analyzer_executions_total[5m]))",
