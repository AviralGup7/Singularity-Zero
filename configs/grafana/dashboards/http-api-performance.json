        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Request Rate by Status Class",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(cyber_pipeline_http_requests_total{status=~\"2..\"}[5m]))",
          "legendFormat": "2xx Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cyber_pipeline_http_requests_total{status=~\"4..\"}[5m]))",
          "legendFormat": "4xx Client Error",
          "refId": "B"
        },
        {
          "expr": "sum(rate(cyber_pipeline_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx Server Error",
          "refId": "C"
