{
  "target_name": "audit-quick",
  "output_dir": "output",
  "http_timeout_seconds": 3,
  "mode": "safe",
  "cache": {
    "enabled": false
  },
  "tools": {
    "subfinder": false,
    "assetfinder": false,
    "amass": false,
    "httpx": false,
    "gau": false,
    "waybackurls": false,
    "katana": false,
    "nuclei": false,
    "timeout_seconds": 15,
    "retry_attempts": 1,
    "retry_backoff_seconds": 0.0,
    "retry_backoff_multiplier": 1.0,
    "retry_max_backoff_seconds": 0.0,
    "retry_on_timeout": true,
    "retry_on_error": true
  },
  "httpx": {
    "threads": 20,
    "batch_size": 20,
    "batch_concurrency": 2,
    "fallback_threads": 16,
    "timeout_seconds": 2,
    "probe_timeout_seconds": 2,
    "extra_args": []
  },
  "analysis": {
    "enabled": true
  },
  "filters": {
    "priority_limit": {
      "default": 10
    },
    "max_collected_urls": 50,
    "ignore_extensions": [],
    "priority_keywords": [],
    "stage_timeout_overrides": {
      "passive_scan": 1,
      "active_scan": 1,
      "semgrep": 1,
      "validation": 1,
      "intelligence": 1
    }
  }
}
