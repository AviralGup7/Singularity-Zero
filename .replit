modules = ["python-3.12", "nodejs-20", "bash", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["borgbackup", "cacert", "cargo", "libiconv", "libxcrypt", "libyaml", "openssl", "pkg-config", "rustc", "xsimd"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start backend"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Start backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "mkdir -p output && python -m uvicorn start_backend:app --host 0.0.0.0 --port 8080"
waitForPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5173
externalPort = 5173

# SECURITY: the backend (port 8080) is no longer exposed publicly. The
# previous mapping forwarded the FastAPI dashboard (which has the
# /api/csrf-token, /api/security/*, /api/mesh/elect-leader and other
# admin surfaces) to the public internet without TLS. In production the
# dashboard should be served through a TLS-terminating reverse proxy
# (nginx + cert-manager) and never through Replit's port forwarding.
# Uncomment the block below ONLY for local development; leave it
# commented for any deployment that touches real data.
# [[ports]]
# localPort = 8080
# externalPort = 8080

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd frontend && npm run build"]
publicDir = "frontend/dist"
