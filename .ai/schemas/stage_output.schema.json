{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StageOutput",
  "type": "object",
  "properties": {
    "contract_version": { "type": "string", "const": "v1" },
    "stage_name": { "type": "string" },
    "outcome": { "enum": ["completed", "failed", "skipped"] },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "retry_count": { "type": "integer", "minimum": 0 },
    "reason": { "type": "string" },
    "error": { "type": "string" },
    "metrics": { "type": "object" },
    "artifacts": { "type": "object" },
    "state_delta": { "type": "object" }
  },
  "required": ["stage_name", "outcome", "duration_seconds"]
}
