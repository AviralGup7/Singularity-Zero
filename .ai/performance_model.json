{
  "version": "2.0",
  "description": "Per-tool memory profile model for accurate resource prediction",
  "tool_profiles": {
    "nuclei": {
      "base_ram_mb": 2048,
      "per_template_mb": 0.5,
      "max_templates_default": 5000,
      "notes": "nuclei loads full template set into memory"
    },
    "httpx": {
      "base_ram_mb": 256,
      "per_1000_urls_mb": 64,
      "notes": "concurrent connection pool memory"
    },
    "katana": {
      "base_ram_mb": 512,
      "crawl_depth_multiplier": 1.5,
      "notes": "depth crawls hold concurrent connection state"
    },
    "semgrep": {
      "base_ram_mb": 1024,
      "per_rule_set_mb": 128,
      "max_rule_sets": 4,
      "notes": "memory scales with loaded rule sets"
    },
    "subfinder": {
      "base_ram_mb": 128,
      "notes": "passive subdomain enumeration, low memory"
    },
    "naabu": {
      "base_ram_mb": 256,
      "per_10000_ports_mb": 64,
      "notes": "port scan state memory"
    },
    "default": {
      "base_ram_mb": 128,
      "notes": "fallback for unlisted tools"
    }
  },
  "concurrent_tool_memory_multiplier": 1.4,
  "oom_guard": {
    "enabled": true,
    "reserve_ram_mb": 2048,
    "kill_ram_mb": 0.90,
    "action_on_oom": "skip_stage",
    "check_interval_seconds": 30
  },
  "stage_baselines": {
    "active_scan": {
      "complexity": "O(n * log(n))",
      "concurrency_cap": 50,
      "notes": "Cap concurrent active scan workers at 50"
    },
    "subdomains": {
      "complexity": "linear",
      "concurrency_cap": 10
    },
    "urls": {
      "complexity": "linear",
      "concurrency_cap": 10
    }
  },
  "stage_tools": {
    "active_scan": ["nuclei", "httpx", "katana", "naabu"],
    "active_scan_adaptive": ["nuclei", "httpx", "katana", "naabu"],
    "subdomains": ["subfinder"],
    "urls": ["katana", "httpx"],
    "semgrep": ["semgrep"],
    "iac_scan": ["semgrep"],
    "sca_scan": ["default"],
    "container_scan": ["default"],
    "git_diff_crawl": ["katana"],
    "probe_runners": ["nuclei"],
    "probe_suites": ["nuclei"],
    "access_control": ["nuclei", "httpx"],
    "validation": ["httpx"],
    "finding_revalidation": ["httpx"],
    "waf": ["httpx"],
    "git_secret_scan": ["default"],
    "sbom_generate": ["default"],
    "sbom_diff": ["default"],
    "reporting": ["default"],
    "report_distribution": ["default"],
    "sarif_export": ["default"],
    "threat_modeling": ["default"],
    "adaptive_extra": ["default"],
    "subdomain_takeover": ["subfinder"]
  },
  "ram_formula": "sum(tool_profile[i].base_ram + tool_profile[i].variable_ram_for(targets)) * concurrent_tool_memory_multiplier + reserve_ram"
}