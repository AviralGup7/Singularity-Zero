{
  "version": "2.0",
  "system": {
    "name": "Cyber Security Test Pipeline",
    "description": "Automated, adaptive API security testing platform",
    "supported_layers": ["core", "recon", "analysis", "detection", "pipeline", "infrastructure", "execution", "intelligence", "dashboard", "reporting", "learning"],
    "concurrency_model": "asyncio (intra-process) + local-mesh (distributed)",
    "checkpoint_version": "v1"
  },
  "stages": [
    {
      "name": "subdomains",
      "label": "Subdomain enumeration",
      "timeout_seconds": 600,
      "parallelizable": false,
      "dependencies": [],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.recon:run_subdomain_enumeration",
      "produces": ["subdomains"],
      "retry_policy": {"max_attempts": 3, "backoff": "exponential"}
    },
    {
      "name": "live_hosts",
      "label": "Live host probing",
      "timeout_seconds": 900,
      "parallelizable": false,
      "dependencies": ["subdomains"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.recon:run_live_hosts",
      "produces": ["live_hosts"],
      "retry_policy": {"max_attempts": 3, "backoff": "exponential"}
    },
    {
      "name": "urls",
      "label": "URL collection",
      "timeout_seconds": 900,
      "parallelizable": false,
      "dependencies": ["live_hosts"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.recon:run_url_collection",
      "produces": ["urls"],
      "retry_policy": {"max_attempts": 3, "backoff": "exponential"}
    },
    {
      "name": "parameters",
      "label": "Parameter extraction",
      "timeout_seconds": 120,
      "parallelizable": false,
      "dependencies": ["urls"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.recon:run_parameter_extraction",
      "produces": ["parameters"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "ranking",
      "label": "Priority ranking",
      "timeout_seconds": 60,
      "parallelizable": false,
      "dependencies": ["urls", "parameters"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.recon:run_priority_ranking",
      "produces": ["ranked_targets"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "passive_scan",
      "label": "Passive analysis",
      "timeout_seconds": 300,
      "parallelizable": false,
      "dependencies": ["ranking", "live_hosts", "urls"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.analysis:run_passive_scanning",
      "produces": ["passive_findings"],
      "retry_policy": {"max_attempts": 2, "backoff": "exponential"}
    },
    {
      "name": "active_scan",
      "label": "Active probing",
      "timeout_seconds": 900,
      "parallelizable": false,
      "dependencies": ["passive_scan"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.active_scan:run_active_scanning",
      "produces": ["active_findings"],
      "retry_policy": {"max_attempts": 2, "backoff": "exponential"}
    },
    {
      "name": "semgrep",
      "label": "Static analysis (Semgrep)",
      "timeout_seconds": 600,
      "parallelizable": true,
      "dependencies": ["passive_scan"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.semgrep:run_semgrep_stage",
      "produces": ["semgrep_findings"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "nuclei",
      "label": "Nuclei vulnerability scanning",
      "timeout_seconds": 600,
      "parallelizable": true,
      "dependencies": ["passive_scan"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.nuclei:run_nuclei_stage",
      "produces": ["nuclei_findings"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "access_control",
      "label": "Authorization bypass detection",
      "timeout_seconds": 600,
      "parallelizable": true,
      "dependencies": ["ranking", "passive_scan"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.access_control:run_access_control_testing",
      "produces": ["access_control_findings"],
      "retry_policy": {"max_attempts": 2, "backoff": "exponential"}
    },
    {
      "name": "validation",
      "label": "Validation runtime",
      "timeout_seconds": 300,
      "parallelizable": false,
      "dependencies": ["passive_scan", "active_scan"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.validation:run_validation",
      "produces": ["validated_findings"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "intelligence",
      "label": "Intelligence merge",
      "timeout_seconds": 180,
      "parallelizable": false,
      "dependencies": ["passive_scan", "active_scan", "nuclei", "validation"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.enrichment:run_post_analysis_enrichments",
      "produces": ["enriched_findings"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "reporting",
      "label": "Report generation",
      "timeout_seconds": 300,
      "parallelizable": false,
      "dependencies": ["intelligence", "nuclei", "access_control", "validation", "passive_scan"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.reporting:run_reporting",
      "produces": ["report_artifacts"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "sca_scan",
      "label": "SCA dependency scan",
      "timeout_seconds": 600,
      "parallelizable": true,
      "dependencies": ["ranking", "live_hosts"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.sca_scan:run_sca_scan_stage",
      "produces": ["sca_findings", "dependency_tree", "sbom_fragment"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "container_scan",
      "label": "Container image scan",
      "timeout_seconds": 900,
      "parallelizable": true,
      "dependencies": ["ranking", "live_hosts"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.container_scan:run_container_scan_stage",
      "produces": ["container_findings", "image_vulns", "sbom_fragment"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "iac_scan",
      "label": "IaC security scan",
      "timeout_seconds": 600,
      "parallelizable": true,
      "dependencies": ["ranking"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.iac_scan:run_iac_scan_stage",
      "produces": ["iac_findings", "misconfigurations"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "sbom_generate",
      "label": "SBOM generation",
      "timeout_seconds": 120,
      "parallelizable": false,
      "dependencies": ["sca_scan", "container_scan"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.sbom_generate:run_sbom_generate_stage",
      "produces": ["sbom", "sbom_cyclonedx", "sbom_spdx"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "sbom_diff",
      "label": "SBOM diff",
      "timeout_seconds": 120,
      "parallelizable": false,
      "dependencies": ["sbom_generate"],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.sbom_diff:run_sbom_diff_stage",
      "produces": ["sbom_diff", "new_components", "removed_components", "changed_components"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    },
    {
      "name": "git_secret_scan",
      "label": "Git secret scan",
      "timeout_seconds": 600,
      "parallelizable": true,
      "dependencies": [],
      "entry_point": "src.pipeline.services.pipeline_orchestrator.stages.git_secret_scan:run_git_secret_scan_stage",
      "produces": ["secret_findings", "exposed_credentials_count"],
      "retry_policy": {"max_attempts": 2, "backoff": "fixed"}
    }
  ],
  "pipeline_profiles": {
    "default": {
      "sca_scan": {"enabled": false, "requires": ["package.json"]},
      "container_scan": {"enabled": false, "requires": ["Dockerfile", "image_reference"]},
      "iac_scan": {"enabled": false, "requires": [".tf", ".yaml"]},
      "sbom_generate": {"enabled": false},
      "sbom_diff": {"enabled": false},
      "git_secret_scan": {"enabled": true}
    },
    "full": {
      "sca_scan": {"enabled": true},
      "container_scan": {"enabled": true},
      "iac_scan": {"enabled": true},
      "sbom_generate": {"enabled": true},
      "sbom_diff": {"enabled": true},
      "git_secret_scan": {"enabled": true}
    }
  },
  "extension_points": [
    {
      "name": "detector",
      "interface": "src.detection.base.Detector",
      "registration": "src.detection.registry:register_detector"
    },
    {
      "name": "stage_runner",
      "interface": "Callable[..., Any]",
      "registration": "src.pipeline.services.plugin_catalog:register_plugin"
    },
    {
      "name": "scope_parser",
      "interface": "src.analysis.bug_bounty.scope_parser.ProgramScope",
      "registration": "src.analysis.bug_bounty.scope_parser:parse_hackerone_scope / parse_bugcrowd_scope"
    },
    {
      "name": "report_template",
      "interface": "src.analysis.bug_bounty.report_templates.ReportTemplate",
      "registration": "src.analysis.bug_bounty.report_templates:format_hackerone / format_bugcrowd"
    },
    {
      "name": "finding_deduplicator",
      "interface": "src.analysis.bug_bounty.dedup.FindingDedup",
      "registration": "src.analysis.bug_bounty.dedup:FindingDedup"
    }
  ],
  "bug_bounty": {
    "capabilities": [
      {
        "name": "program_scope",
        "description": "Parse HackerOne/Bugcrowd scope text into structured ProgramScope (target URLs, wildcards, exclusions).",
        "entry_points": [
          "src.analysis.bug_bounty.scope_parser:parse_hackerone_scope",
          "src.analysis.bug_bounty.scope_parser:parse_bugcrowd_scope",
          "src.analysis.bug_bounty.scope_parser:expand_wildcards",
          "src.analysis.bug_bounty.scope_parser:filter_out_of_scope"
        ]
      },
      {
        "name": "finding_deduplication",
        "description": "Fingerprint and deduplicate findings against previously submitted reports.",
        "entry_points": [
          "src.analysis.bug_bounty.dedup:FindingDedup",
          "src.analysis.bug_bounty.dedup:FindingDedup.fingerprint_finding",
          "src.analysis.bug_bounty.dedup:FindingDedup.is_duplicate"
        ]
      },
      {
        "name": "report_template_generation",
        "description": "Generate platform-specific HackerOne or Bugcrowd report payloads from internal finding representations.",
        "entry_points": [
          "src.analysis.bug_bounty.report_templates:ReportTemplate.format_hackerone",
          "src.analysis.bug_bounty.report_templates:ReportTemplate.format_bugcrowd"
        ]
      }
    ],
    "stages": [
      {
        "name": "scope_stage",
        "runner": "src.pipeline.services.pipeline_orchestrator.stages.scope_stage:run_scope_stage",
        "needs": ["target_urls"],
        "produces": ["in_scope_urls", "out_of_scope_urls", "scope_metadata"],
        "description": "Filters collected URLs against the configured bug bounty scope. Skippable when no program scope is configured."
      },
      {
        "name": "dedup_stage",
        "runner": "src.pipeline.services.pipeline_orchestrator.stages.dedup_stage:run_dedup_stage",
        "needs": ["reportable_findings", "submitted_findings_store"],
        "produces": ["new_findings", "duplicate_findings"],
        "description": "Separates new findings from duplicates against the configured submitted-findings store. Skippable when no store is configured."
      }
    ]
  }
}
