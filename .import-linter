[importlinter]
root_package = src

[importlinter:contract:1]
name = "Infrastructure must not depend on analysis"
type = forbidden
source_modules = src.infrastructure
forbidden_modules = src.analysis

[importlinter:contract:2]
name = "Dashboard must not depend on pipeline internals"
type = forbidden
source_modules = src.dashboard.fastapi.routers
forbidden_modules = src.pipeline.services

[importlinter:contract:3]
name = "Analysis subpackages are independent"
type = independence
modules =
    src.analysis.passive
    src.analysis.active
    src.analysis.json
    src.analysis.response
    src.analysis.behavior

[importlinter:contract:4]
name = "Core has no outward dependencies"
type = forbidden
source_modules = src.core
forbidden_modules = src.analysis, src.pipeline, src.dashboard

[importlinter:contract:5]
name = "Facade pattern: detection must not import from analysis"
type = forbidden
source_modules = src.detection
forbidden_modules = src.analysis

[importlinter:contract:5b]
name = "Facade pattern: decision must not import from analysis"
type = forbidden
source_modules = src.decision
forbidden_modules = src.analysis

[importlinter:contract:6]
name = "Core must not depend on infrastructure"
type = forbidden
source_modules = src.core
forbidden_modules = src.infrastructure

[importlinter:contract:7]
name = "Core must not depend on execution"
type = forbidden
source_modules = src.core
forbidden_modules = src.execution

[importlinter:contract:8]
name = "Execution must not depend on analysis (circular coupling fix)"
type = forbidden
source_modules = src.execution
forbidden_modules = src.analysis

[importlinter:contract:9]
name = "Core exploiters must not depend on execution or pipeline"
type = forbidden
source_modules = src.core.exploiters
forbidden_modules = src.execution, src.pipeline

[importlinter:contract:10]
name = "Core tools must not depend on execution or pipeline"
type = forbidden
source_modules = src.core.tools
forbidden_modules = src.execution, src.pipeline

[importlinter:contract:11]
name = Dashboard must not depend on analysis
type = forbidden
source_modules = src.dashboard
forbidden_modules = src.analysis

[importlinter:contract:12]
name = Dashboard must not depend on execution
type = forbidden
source_modules = src.dashboard
forbidden_modules = src.execution

[importlinter:contract:13]
name = Dashboard must not depend on pipeline internals
type = forbidden
source_modules = src.dashboard
forbidden_modules = src.pipeline

[importlinter:contract:14]
name = Pipeline must not depend on execution
type = forbidden
source_modules = src.pipeline
forbidden_modules = src.execution

[importlinter:contract:15]
name = Execution must not depend on analysis
type = forbidden
source_modules = src.execution
forbidden_modules = src.analysis

[importlinter:contract:16]
name = Execution must not depend on pipeline
type = forbidden
source_modules = src.execution
forbidden_modules = src.pipeline

[importlinter:contract:17]
name = Infrastructure must not depend on pipeline
type = forbidden
source_modules = src.infrastructure
forbidden_modules = src.pipeline

[importlinter:contract:18]
name = Core must not depend on fuzzing
type = forbidden
source_modules = src.core
forbidden_modules = src.fuzzing
