{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ],
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run check:copy-guard",
    "build": "tsc -b && vite build && npm run check:anim-budget",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:audit": "playwright test tests/audit/",
    "test:e2e:headed": "playwright test --headed",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "check:bundle": "npm run build && npx size-limit",
    "check:types": "tsc --noEmit",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix --force",
    "lint:security": "npx eslint src/ --plugin security --format compact",
    "build:analyze": "npx vite build --mode analyze",
    "check:size": "npx size-limit",
    "check:anim-budget": "node ./scripts/check-animation-budget.mjs",
    "check:copy-guard": "node ./scripts/copy-guard.mjs",
    "health": "echo 'Running full health check...' && npm run check:types && npm run lint && npm run check:copy-guard && npm run build && npm run audit && npm run check:size"
  },
